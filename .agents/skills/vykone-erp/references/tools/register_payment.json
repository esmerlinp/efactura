{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "tool_name": "register_payment",
  "display_name": "Registrar Pago de Factura",
  "description": "Registra un pago recibido de cliente contra una o múltiples facturas pendientes (CxC). Soporta pago parcial, distribución FIFO, retención ISR/ITBIS, y múltiples métodos de pago (transferencia, efectivo, cheque, tarjeta).",
  "category": "payment",
  "risk_level": "medium",
  "idempotency": "not idempotent (creates new payment each call)",
  "permissions": ["payments:write"],
  "related_process": "BP-4 Pago de Factura",

  "input_schema": {
    "type": "object",
    "required": ["owner_uid", "customer_id", "payment_method", "payment_date", "total_amount", "invoices"],
    "properties": {
      "owner_uid": {
        "type": "string",
        "description": "Identificador del tenant/empresa"
      },
      "customer_id": {
        "type": "string",
        "description": "ID del cliente que realiza el pago"
      },
      "payment_method": {
        "type": "string",
        "enum": ["transferencia", "efectivo", "cheque", "tarjeta"],
        "description": "Método de pago utilizado"
      },
      "payment_date": {
        "type": "string",
        "format": "date",
        "description": "Fecha en que se recibió el pago (YYYY-MM-DD)"
      },
      "total_amount": {
        "type": "number",
        "exclusiveMinimum": 0,
        "description": "Monto total del pago en RD$"
      },
      "reference": {
        "type": "string",
        "description": "Número de referencia o comprobante externo"
      },
      "notes": {
        "type": "string",
        "description": "Notas adicionales sobre el pago"
      },
      "invoices": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["invoice_id", "amount_to_apply"],
          "properties": {
            "invoice_id": {"type": "string", "description": "ID de la factura a pagar"},
            "amount_to_apply": {"type": "number", "exclusiveMinimum": 0, "description": "Monto a aplicar de este pago a esta factura"},
            "retencion_isr": {"type": "number", "minimum": 0, "description": "Retención ISR aplicada (si corresponde)"},
            "retencion_itbis": {"type": "number", "minimum": 0, "description": "Retención ITBIS aplicada (si corresponde)"}
          }
        },
        "description": "Lista de facturas a las que se aplica este pago"
      },
      "payment_details": {
        "type": "object",
        "description": "Detalles específicos según método de pago",
        "properties": {
          "transferencia": {
            "type": "object",
            "properties": {
              "banco_origen": {"type": "string"},
              "banco_destino": {"type": "string"},
              "referencia_bancaria": {"type": "string"},
              "cuenta_destino_id": {"type": "string"}
            }
          },
          "efectivo": {
            "type": "object",
            "properties": {
              "caja_id": {"type": "string"}
            }
          },
          "cheque": {
            "type": "object",
            "properties": {
              "numero_cheque": {"type": "string"},
              "banco": {"type": "string"},
              "fecha_cobro_estimada": {"type": "string", "format": "date"}
            }
          },
          "tarjeta": {
            "type": "object",
            "properties": {
              "ultimos_4_digitos": {"type": "string", "pattern": "^\\d{4}$"},
              "tipo_tarjeta": {"type": "string", "enum": ["visa", "mastercard", "amex", "other"]},
              "autorizacion": {"type": "string"},
              "lote_id": {"type": "string"}
            }
          }
        }
      }
    }
  },

  "output_schema": {
    "type": "object",
    "properties": {
      "payment_id": {"type": "string", "description": "ID del pago registrado"},
      "total_paid": {"type": "number", "description": "Total aplicado a facturas"},
      "total_retencion_isr": {"type": "number"},
      "total_retencion_itbis": {"type": "number"},
      "invoices_paid": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "invoice_id": {"type": "string"},
            "amount_applied": {"type": "number"},
            "remaining_balance": {"type": "number"},
            "new_status": {"type": "string", "enum": ["Pagada", "Pendiente"]}
          }
        }
      },
      "accounting_entry_id": {"type": "string", "description": "ID del asiento contable generado"},
      "created_at": {"type": "string", "format": "date-time"}
    }
  },

  "validations": [
    {"field": "invoices[].invoice_id", "rule": "Debe existir y estar en estado Pendiente o Vencida"},
    {"field": "invoices[].amount_to_apply", "rule": "No puede exceder el balance pendiente de la factura"},
    {"field": "total_amount", "rule": "Debe ser igual a Σ(amount_to_apply) de todas las facturas"},
    {"field": "payment_details", "rule": "Debe incluir los campos requeridos según payment_method seleccionado"}
  ],

  "errors": [
    {"code": "INVOICE_NOT_FOUND", "message": "Factura {invoice_id} no encontrada."},
    {"code": "INVOICE_ALREADY_PAID", "message": "Factura {invoice_id} ya está pagada completamente."},
    {"code": "AMOUNT_EXCEEDS_BALANCE", "message": "Monto RD${amount} excede el balance pendiente de RD${balance} en factura {invoice_id}."},
    {"code": "AMOUNT_MISMATCH", "message": "El total_amount RD${total} no coincide con la suma de amounts_to_apply RD${sum}."},
    {"code": "INVALID_PAYMENT_DETAILS", "message": "Faltan campos requeridos para el método de pago {method}: {missing_fields}."},
    {"code": "CUSTOMER_MISMATCH", "message": "La factura {invoice_id} pertenece a otro cliente."}
  ],

  "post_effects": {
    "events": ["InvoicePaid", "PaymentRegistered"],
    "accounting": "auto (Bank/Cash debit, CxC credit, retention accounts if applicable)",
    "notifications": ["email_receipt to customer (configurable)"]
  },

  "example": {
    "input": {
      "owner_uid": "abc123def456",
      "customer_id": "cust_001",
      "payment_method": "transferencia",
      "payment_date": "2026-07-08",
      "total_amount": 100000.00,
      "reference": "PAGO-JUL-001",
      "invoices": [
        {
          "invoice_id": "inv_2026-001",
          "amount_to_apply": 50000.00,
          "retencion_isr": 5000.00,
          "retencion_itbis": 0.00
        },
        {
          "invoice_id": "inv_2026-002",
          "amount_to_apply": 50000.00
        }
      ],
      "payment_details": {
        "transferencia": {
          "banco_origen": "Banco Popular",
          "banco_destino": "Banreservas",
          "referencia_bancaria": "TRF-987654",
          "cuenta_destino_id": "cta_ban_001"
        }
      }
    },
    "output": {
      "payment_id": "pay_20260708_001",
      "total_paid": 100000.00,
      "total_retencion_isr": 5000.00,
      "total_retencion_itbis": 0.00,
      "invoices_paid": [
        {"invoice_id": "inv_2026-001", "amount_applied": 50000.00, "remaining_balance": 0.00, "new_status": "Pagada"},
        {"invoice_id": "inv_2026-002", "amount_applied": 50000.00, "remaining_balance": 15000.00, "new_status": "Pendiente"}
      ],
      "accounting_entry_id": "asiento_20260708_045",
      "created_at": "2026-07-08T10:15:00Z"
    }
  }
}
