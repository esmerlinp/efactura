{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "tool_name": "register_bank_reconciliation",
  "display_name": "Registrar Conciliación Bancaria",
  "description": "Ejecuta el proceso de conciliación bancaria: importa extracto, aplica matching automático por monto/fecha, genera reporte de diferencias, y permite registrar ajustes. Retorna el estado de conciliación y las partidas no conciliadas.",
  "category": "banking",
  "risk_level": "high",
  "idempotency": "idempotent per period (updates existing reconciliation if period already started)",
  "permissions": ["banking:write"],
  "related_process": "BP-8 Conciliación Bancaria",

  "input_schema": {
    "type": "object",
    "required": ["owner_uid", "bank_account_id", "period_start", "period_end"],
    "properties": {
      "owner_uid": {"type": "string", "description": "Identificador del tenant/empresa"},
      "bank_account_id": {"type": "string", "description": "ID de la cuenta bancaria a conciliar"},
      "period_start": {"type": "string", "format": "date", "description": "Inicio del período (YYYY-MM-DD)"},
      "period_end": {"type": "string", "format": "date", "description": "Fin del período (YYYY-MM-DD)"},
      "statement_data": {
        "type": "array",
        "description": "Transacciones del extracto bancario. Si no se envía, se usan las ya importadas.",
        "items": {
          "type": "object",
          "required": ["fecha", "descripcion", "monto", "tipo"],
          "properties": {
            "fecha": {"type": "string", "format": "date"},
            "descripcion": {"type": "string"},
            "monto": {"type": "number", "exclusiveMinimum": 0},
            "tipo": {"type": "string", "enum": ["debito", "credito"]},
            "referencia": {"type": "string"}
          }
        }
      },
      "auto_match": {
        "type": "boolean",
        "default": true,
        "description": "Ejecutar matching automático después de cargar el extracto"
      },
      "match_tolerance_days": {
        "type": "integer",
        "minimum": 0,
        "maximum": 10,
        "default": 2,
        "description": "Tolerancia en días para matching por fecha"
      },
      "adjustments": {
        "type": "array",
        "description": "Ajustes manuales a registrar (comisiones ITF, cargos no contabilizados, etc.)",
        "items": {
          "type": "object",
          "required": ["tipo", "monto", "cuenta_contable", "descripcion"],
          "properties": {
            "tipo": {"type": "string", "enum": ["cargo_bancario", "ingreso_no_registrado", "cheque_transito", "deposito_transito", "ajuste_manual"]},
            "monto": {"type": "number"},
            "cuenta_contable": {"type": "string", "description": "Cuenta contable a debitar/acreditar"},
            "descripcion": {"type": "string"},
            "fecha": {"type": "string", "format": "date"}
          }
        }
      },
      "finalize": {
        "type": "boolean",
        "default": false,
        "description": "Si true, finaliza y bloquea la conciliación"
      }
    }
  },

  "output_schema": {
    "type": "object",
    "properties": {
      "reconciliation_id": {"type": "string"},
      "status": {"type": "string", "enum": ["pending", "in_progress", "reconciled", "dispute"]},
      "period": {"type": "object", "properties": {"start": {"type": "string"}, "end": {"type": "string"}}},
      "summary": {
        "type": "object",
        "properties": {
          "balance_libros_inicial": {"type": "number"},
          "balance_banco_inicial": {"type": "number"},
          "total_matched": {"type": "integer", "description": "Cantidad de partidas matched"},
          "total_unmatched_banco": {"type": "integer", "description": "Partidas en banco no en ERP"},
          "total_unmatched_erp": {"type": "integer", "description": "Partidas en ERP no en banco"},
          "diferencia_neta": {"type": "number", "description": "Diferencia después de ajustes (debe ser 0)"}
        }
      },
      "unmatched_items": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "source": {"type": "string", "enum": ["banco", "erp"]},
            "fecha": {"type": "string"},
            "descripcion": {"type": "string"},
            "monto": {"type": "number"},
            "tipo": {"type": "string"},
            "suggested_match": {"type": "string", "description": "Sugerencia de partida ERP correspondiente"}
          }
        }
      },
      "adjustments_applied": {"type": "integer"},
      "accounting_entry_id": {"type": "string", "description": "ID del asiento de ajustes (si aplica)"},
      "created_at": {"type": "string", "format": "date-time"}
    }
  },

  "validations": [
    {"field": "period_start/end", "rule": "period_start <= period_end, período no debe estar ya conciliado"},
    {"field": "bank_account_id", "rule": "Cuenta debe existir y estar activa"},
    {"field": "adjustments[].monto", "rule": "No pueden crear diferencias negativas no explicadas"}
  ],

  "errors": [
    {"code": "ACCOUNT_NOT_FOUND", "message": "Cuenta bancaria {id} no encontrada."},
    {"code": "PERIOD_ALREADY_RECONCILED", "message": "El período {start}-{end} ya fue conciliado para esta cuenta."},
    {"code": "UNEXPLAINED_DIFFERENCE", "message": "Diferencia de RD${amount} no explicada al finalizar. Agregue ajustes antes de finalizar."},
    {"code": "STATEMENT_PARSE_ERROR", "message": "No se pudo interpretar el extracto bancario. Verifique el formato."}
  ],

  "post_effects": {
    "events": ["BankAccountReconciled"],
    "accounting": "auto (adjustment entries for ITF, commissions, etc.)"
  },

  "example": {
    "input": {
      "owner_uid": "abc123def456",
      "bank_account_id": "cta_ban_001",
      "period_start": "2026-06-01",
      "period_end": "2026-06-30",
      "auto_match": true,
      "match_tolerance_days": 2,
      "adjustments": [
        {"tipo": "cargo_bancario", "monto": 250.00, "cuenta_contable": "6-1-01-001", "descripcion": "ITF Junio 2026", "fecha": "2026-06-30"},
        {"tipo": "cheque_transito", "monto": 15000.00, "cuenta_contable": "1-1-01-001", "descripcion": "Cheque #4523 no cobrado", "fecha": "2026-06-28"}
      ],
      "finalize": true
    },
    "output": {
      "reconciliation_id": "rec_202606_001",
      "status": "reconciled",
      "period": {"start": "2026-06-01", "end": "2026-06-30"},
      "summary": {
        "balance_libros_inicial": 250000.00,
        "balance_banco_inicial": 234750.00,
        "total_matched": 47,
        "total_unmatched_banco": 0,
        "total_unmatched_erp": 1,
        "diferencia_neta": 0.00
      },
      "unmatched_items": [],
      "adjustments_applied": 2,
      "accounting_entry_id": "asiento_20260708_046",
      "created_at": "2026-07-08T11:00:00Z"
    }
  }
}
